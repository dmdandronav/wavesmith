{
  "name": "wavesmith",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Chiptune patterns forged into real .wav files — oscillators, envelopes, RIFF/PCM16 written byte by byte. No audio-encoding library.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.1.0",
    "@fontsource/space-mono": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^6.0.1",
    "vitest": "^2.1.5",
    "wav-decoder": "^1.3.0"
  }
}
